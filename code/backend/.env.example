# Read-Box 后端环境变量配置
# 使用方式：复制此文件为 .env，按需修改
# cp .env.example .env

READBOX_PORT=               # 后端监听端口（留空则使用默认）
DATABASE_URL=sqlite+aiosqlite:///readbox.db  # SQLite 数据库路径

# --- LLM Provider 配置 ---
# 支持的 provider_type: openai / claude / ollama
LLM_PROVIDER=openai          # AI 模型类型
LLM_API_KEY=                 # API 密钥（必填，在此填入你的 API Key）
LLM_API_BASE=https://api.deepseek.com  # API 地址
LLM_MODEL=                   # 模型名称（如 deepseek-chat）
LLM_MAX_TOKENS=4096          # 最大输出 token 数
LLM_TEMPERATURE=0.7          # 生成温度（0-1）
